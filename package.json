{
  "name": "octagons",
  "version": "0.1.1",
  "description": "Animated backgrounds built from regular octagons. Line art, zero dependencies.",
  "main": "octagons.js",
  "files": [
    "octagons.js",
    "octagons.min.js",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "terser octagons.js --compress --mangle -o octagons.min.js",
    "size": "terser octagons.js --compress --mangle | gzip -9 | wc -c",
    "lint": "eslint .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "octagon",
    "octagons",
    "background",
    "canvas",
    "animation",
    "generative",
    "generative-art",
    "line-art",
    "geometric",
    "pattern",
    "tiling",
    "zero-dependencies",
    "vanilla-js",
    "hero-background",
    "background-animation",
    "svg-pattern"
  ],
  "author": "301st (https://301.st)",
  "license": "MIT",
  "homepage": "https://github.com/investblog/octagons#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/investblog/octagons.git"
  },
  "bugs": {
    "url": "https://github.com/investblog/octagons/issues"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "terser": "^5.37.0"
  }
}
