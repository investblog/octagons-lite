{
  "name": "octagons-lite",
  "version": "0.1.0",
  "description": "Animated backgrounds built from regular octagons. Line art, zero dependencies.",
  "main": "octagons-lite.js",
  "files": [
    "octagons-lite.js",
    "octagons-lite.min.js"
  ],
  "scripts": {
    "build": "npx terser octagons-lite.js --compress --mangle -o octagons-lite.min.js",
    "size": "npx terser octagons-lite.js --compress --mangle | gzip -9 | wc -c",
    "lint": "npx eslint .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "octagon",
    "background",
    "canvas",
    "animation",
    "generative",
    "line-art",
    "lightweight"
  ],
  "author": "301ST (https://301.st)",
  "license": "MIT",
  "homepage": "https://github.com/investblog/octagons-lite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/investblog/octagons-lite.git"
  },
  "bugs": {
    "url": "https://github.com/investblog/octagons-lite/issues"
  }
}
